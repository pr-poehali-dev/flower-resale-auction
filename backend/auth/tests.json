{
  "tests": [
    {
      "name": "Wrong phone+password returns 401",
      "method": "POST",
      "path": "/?action=login",
      "body": {"phone": "+70000000000", "password": "wrongpass"},
      "expectedStatus": 401,
      "bodyMatcher": "none"
    },
    {
      "name": "Wrong email+password returns 401",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "nobody@example.com", "password": "wrongpass"},
      "expectedStatus": 401,
      "bodyMatcher": "none"
    },
    {
      "name": "Forgot password always returns 200",
      "method": "POST",
      "path": "/?action=forgot_password",
      "body": {"email": "nobody@example.com"},
      "expectedStatus": 200,
      "bodyMatcher": "none"
    }
  ]
}